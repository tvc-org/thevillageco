{% schema %}
{
    "name": "Rewards FAQ Section 1 CTA",
    "settings": [
        {
            "type": "text",
            "id": "text",
            "label": "Text"
        },
        {
            "type": "url",
            "id": "link",
            "label": "Link"
        },
        {
            "type": "checkbox",
            "id": "hide_from_view",
            "label": "Hide From View?"
        }
    ]
}
{% endschema %}

<section class="rewards-yotpo-cta {% if section.settings.hide_from_view == true %}visually-hidden{% endif %}">
    <a href="{{ section.settings.link }}" class="cta cta-3">{{ section.settings.text }}</a>
</section>