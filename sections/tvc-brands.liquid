{{ 'section-tvc-shared.css' | asset_url | stylesheet_tag }}
{{ 'section-tvc-brands.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign tvc_brand_blocks = section.blocks | where: 'type', 'brand'
  assign tvc_brands_anim_offset = 0
  if section.settings.pre_title != blank or section.settings.title != blank
    assign tvc_brands_anim_offset = 1
  endif
  assign tvc_section_anchor = section.settings.anchor_id | strip | remove: '#' | handleize
-%}

<div
  class="tvc-brands"
  {% if tvc_section_anchor != blank %}
    id="{{ tvc_section_anchor }}"
  {% endif %}
>
  <div class="page-width tvc-brands__inner">
    {%- if section.settings.pre_title != blank or section.settings.title != blank -%}
      <div
        class="tvc-brands__header{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        {% if settings.animations_reveal_on_scroll %}
          data-cascade
          style="--animation-order: 0;"
        {% endif %}
      >
        {%- if section.settings.pre_title != blank -%}
          <p class="tvc-pretitle">{{ section.settings.pre_title | escape }}</p>
        {%- endif -%}

        {%- if section.settings.title != blank -%}
          <h2 class="tvc-brands__title tvc-section-title h1 mt-0 mb-4">{{ section.settings.title }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if tvc_brand_blocks.size > 0 -%}
      <ul class="tvc-brands__grid" role="list">
        {%- for block in tvc_brand_blocks -%}
          {%- liquid
            assign tvc_brand_logo = block.settings.logo
            assign tvc_brand_hover = block.settings.hover_image
            assign tvc_brand_bg = block.settings.logo_background_color | default: '#cccccc'
            assign tvc_brand_link = block.settings.link
            assign tvc_brand_title = block.settings.title
            assign tvc_brand_text = block.settings.text
            assign tvc_brand_alt = tvc_brand_title | default: shop.name
          -%}
          <li
            class="tvc-brands__grid-item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index | plus: tvc_brands_anim_offset }};"
            {% endif %}
          >
            {%- if tvc_brand_link != blank -%}
              <a class="tvc-brands__item" href="{{ tvc_brand_link }}">
            {%- else -%}
              <div class="tvc-brands__item">
            {%- endif -%}
            {%- if tvc_brand_logo != blank or tvc_brand_hover != blank -%}
              <div
                class="tvc-brands__logo"
                style="--tvc-brand-bg: {{ tvc_brand_bg }};"
              >
                {%- if tvc_brand_logo != blank -%}
                  <div class="tvc-brands__logo-default">
                    {{
                      tvc_brand_logo
                      | image_url: width: 800
                      | image_tag:
                        loading: 'lazy',
                        widths: '400, 600, 800',
                        sizes: '(min-width: 960px) 33vw, (min-width: 750px) 50vw, 100vw',
                        class: 'tvc-brands__logo-image',
                        alt: tvc_brand_alt
                    }}
                  </div>
                {%- endif -%}

                {%- if tvc_brand_hover != blank -%}
                  <div class="tvc-brands__logo-reveal">
                    {{
                      tvc_brand_hover
                      | image_url: width: 1200
                      | image_tag:
                        loading: 'eager',
                        widths: '600, 900, 1200',
                        sizes: '(min-width: 960px) 33vw, (min-width: 750px) 50vw, 100vw',
                        class: 'tvc-brands__hover-image',
                        alt: tvc_brand_alt,
                        fetchpriority: 'low'
                    }}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}

            {%- if tvc_brand_title != blank or tvc_brand_text != blank -%}
              <div class="tvc-brands__copy">
                {%- if tvc_brand_title != blank -%}
                  <h3 class="tvc-brands__item-title mb-3">{{ tvc_brand_title | escape }}</h3>
                {%- endif -%}
                {%- if tvc_brand_text != blank -%}
                  <p class="tvc-brands__item-text">{{ tvc_brand_text | escape }}</p>
                {%- endif -%}
              </div>
            {%- endif -%}
            {%- if tvc_brand_link != blank -%}
              </a>
            {%- else -%}
              </div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</div>

<script>
  (function () {
    const section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    function primeBrandReveals() {
      section.querySelectorAll('.tvc-brands__logo-reveal').forEach((el) => {
        const savedTransition = el.style.transition;
        el.style.transition = 'none';
        el.style.clipPath = 'circle(51% at 50% 50%)';
        void el.offsetWidth;
        el.style.clipPath = 'circle(0.001% at 50% 50%)';
        void el.offsetWidth;
        el.style.transition = savedTransition;
        el.style.clipPath = '';
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', primeBrandReveals, { once: true });
    } else {
      primeBrandReveals();
    }
  })();
</script>

{% schema %}
{
  "name": "t:sections.tvc-brands.name",
  "tag": "section",
  "class": "section section-tvc-brands",
  "max_blocks": 12,
  "enabled_on": {
    "templates": ["index"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.tvc-brands.settings.header_anchor.content"
    },
    {
      "type": "text",
      "id": "anchor_id",
      "label": "t:sections.tvc-brands.settings.anchor_id.label",
      "info": "t:sections.tvc-brands.settings.anchor_id.info",
      "default": "brands"
    },
    {
      "type": "header",
      "content": "t:sections.tvc-brands.settings.header_content.content"
    },
    {
      "type": "text",
      "id": "pre_title",
      "label": "t:sections.tvc-brands.settings.pre_title.label",
      "default": "Brand portfolio"
    },
    {
      "type": "html",
      "id": "title",
      "label": "t:sections.tvc-brands.settings.title.label",
      "info": "t:sections.tvc-brands.settings.title.info",
      "default": "Our portfolio of\ntrusted personal care brands"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "t:sections.tvc-brands.blocks.brand.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "t:sections.tvc-brands.blocks.brand.settings.logo.label"
        },
        {
          "type": "color",
          "id": "logo_background_color",
          "label": "t:sections.tvc-brands.blocks.brand.settings.logo_background_color.label",
          "default": "#006bb6"
        },
        {
          "type": "image_picker",
          "id": "hover_image",
          "label": "t:sections.tvc-brands.blocks.brand.settings.hover_image.label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.tvc-brands.blocks.brand.settings.title.label"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:sections.tvc-brands.blocks.brand.settings.text.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.tvc-brands.blocks.brand.settings.link.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.tvc-brands.presets.name",
      "category": "Homepage",
      "blocks": [
        {
          "type": "brand"
        },
        {
          "type": "brand"
        },
        {
          "type": "brand"
        }
      ]
    }
  ]
}
{% endschema %}
