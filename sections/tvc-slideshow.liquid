{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-slideshow.css' | asset_url | stylesheet_tag }}
{{ 'section-tvc-slideshow.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign section_classes = 'tvc-slideshow'
  if section.settings.layout == 'stacked'
    assign section_classes = section_classes | append: ' tvc-slideshow--layout-stacked'
  else
    assign section_classes = section_classes | append: ' tvc-slideshow--layout-split'
  endif
  if section.blocks.size > 1
    assign section_classes = section_classes | append: ' tvc-slideshow--has-nav'
  endif
  if section.settings.layout == 'split' and section.blocks.size > 0
    if section.blocks.first.settings.split_media_position == 'left'
      assign section_classes = section_classes | append: ' tvc-slideshow--split-nav-text-right'
    else
      assign section_classes = section_classes | append: ' tvc-slideshow--split-nav-text-left'
    endif
  endif
-%}

<slideshow-component
  class="slider-mobile-gutter {{ section_classes }}"
  role="region"
  aria-roledescription="{{ 'sections.slideshow.carousel' | t }}"
  aria-label="{{ section.settings.accessibility_info | escape }}"
>
  {%- if section.blocks.size > 1 and section.settings.auto_rotate -%}
    <div class="slideshow__controls slideshow__controls--top slider-buttons">
      <button
        type="button"
        class="slider-button slider-button--prev"
        name="previous"
        aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}"
        aria-controls="Slider-{{ section.id }}"
      >
        <span class="svg-wrapper">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </button>
      <div class="slider-counter slider-counter--dots caption">
        <div class="slideshow__control-wrapper">
          {%- for block in section.blocks -%}
            <button
              type="button"
              class="slider-counter__link slider-counter__link--dots link"
              aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
              aria-controls="Slider-{{ section.id }}"
            >
              <span class="dot"></span>
            </button>
          {%- endfor -%}
        </div>
      </div>
      <button
        type="button"
        class="slider-button slider-button--next"
        name="next"
        aria-label="{{ 'sections.slideshow.next_slideshow' | t }}"
        aria-controls="Slider-{{ section.id }}"
      >
        <span class="svg-wrapper">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </button>
      <button
        type="button"
        class="slideshow__autoplay slider-button"
        aria-label="{{ 'sections.slideshow.pause_slideshow' | t }}"
      >
        <span class="svg-wrapper">
          {{- 'icon-pause.svg' | inline_asset_content -}}
        </span>
        <span class="svg-wrapper">
          {{- 'icon-play.svg' | inline_asset_content -}}
        </span>
      </button>
    </div>
  {%- endif -%}

  <div
    class="slideshow banner tvc-slideshow__slider grid grid--1-col slider slider--everywhere{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
    id="Slider-{{ section.id }}"
    aria-live="polite"
    aria-atomic="true"
    data-autoplay="{{ section.settings.auto_rotate }}"
    data-speed="{{ section.settings.change_slides_speed }}"
  >
    {%- for block in section.blocks -%}
      {%- liquid
        assign inner_classes = 'tvc-slideshow__inner'
        if section.settings.layout == 'split'
          if block.settings.split_media_position == 'left'
            assign inner_classes = inner_classes | append: ' tvc-slideshow__inner--media-left'
          else
            assign inner_classes = inner_classes | append: ' tvc-slideshow__inner--media-right'
          endif
          if block.settings.split_text_tone == 'light'
            assign inner_classes = inner_classes | append: ' tvc-slideshow__inner--text-light'
          else
            assign inner_classes = inner_classes | append: ' tvc-slideshow__inner--text-dark'
          endif
        endif
      -%}
      <div
        class="slideshow__slide grid__item slider__slide tvc-slideshow__slide"
        id="Slide-{{ section.id }}-{{ forloop.index }}"
        {{ block.shopify_attributes }}
        role="group"
        aria-roledescription="{{ 'sections.slideshow.slide' | t }}"
        aria-label="{{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
        tabindex="-1"
      >
        <div class="{{ inner_classes }}">
          <div class="tvc-slideshow__media">
            {%- liquid
              assign show_video = false
              if block.settings.media_type == 'video' and block.settings.video != blank
                assign show_video = true
              endif
            -%}
            {%- if show_video -%}
              {{
                block.settings.video
                | video_tag:
                  image_size: '2048x',
                  autoplay: true,
                  loop: true,
                  muted: true,
                  controls: false,
                  class: 'tvc-slideshow__video'
              }}
            {%- elsif block.settings.image != blank -%}
              {%- liquid
                assign height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio | round
                assign sizes = '100vw'
                assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                assign fetch_priority = 'auto'
                if section.index == 1 and forloop.first
                  assign fetch_priority = 'high'
                endif
              -%}
              {%- if forloop.first -%}
                {{
                  block.settings.image
                  | image_url: width: 3840
                  | image_tag:
                    height: height,
                    sizes: sizes,
                    widths: widths,
                    fetchpriority: fetch_priority,
                    class: 'tvc-slideshow__image'
                }}
              {%- else -%}
                {{
                  block.settings.image
                  | image_url: width: 3840
                  | image_tag:
                    loading: 'lazy',
                    height: height,
                    sizes: sizes,
                    widths: widths,
                    class: 'tvc-slideshow__image'
                }}
              {%- endif -%}
            {%- else -%}
              {%- assign placeholder_slide = forloop.index | modulo: 2 -%}
              {%- if placeholder_slide == 1 -%}
                {{ 'hero-apparel-2' | placeholder_svg_tag: 'tvc-slideshow__placeholder placeholder-svg' }}
              {%- else -%}
                {{ 'hero-apparel-1' | placeholder_svg_tag: 'tvc-slideshow__placeholder placeholder-svg' }}
              {%- endif -%}
            {%- endif -%}
          </div>

          <div
            class="tvc-slideshow__panel"
            {% if section.settings.layout == 'split' %}
              style="background-color: {{ block.settings.split_background }};"
            {% endif %}
          >
            {%- if block.settings.heading != blank -%}
              <h2 class="tvc-slideshow__heading h2">{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <div class="tvc-slideshow__body rte">{{ block.settings.text }}</div>
            {%- endif -%}
            {%- if block.settings.link != blank -%}
              {%- liquid
                if block.settings.link_label != blank
                  assign link_label = block.settings.link_label
                else
                  assign link_label = 'Learn more'
                endif
              -%}
              <a href="{{ block.settings.link }}" class="tvc-slideshow__link cta-link">
                {{- link_label | escape -}}
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 and section.settings.auto_rotate == false -%}
    <div class="slideshow__controls slider-buttons">
      <button
        type="button"
        class="slider-button slider-button--prev"
        name="previous"
        aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}"
        aria-controls="Slider-{{ section.id }}"
      >
        <span class="svg-wrapper">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </button>
      <div class="slider-counter slider-counter--dots caption">
        <div class="slideshow__control-wrapper">
          {%- for block in section.blocks -%}
            <button
              type="button"
              class="slider-counter__link slider-counter__link--dots link"
              aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
              aria-controls="Slider-{{ section.id }}"
            >
              <span class="dot"></span>
            </button>
          {%- endfor -%}
        </div>
      </div>
      <button
        type="button"
        class="slider-button slider-button--next"
        name="next"
        aria-label="{{ 'sections.slideshow.next_slideshow' | t }}"
        aria-controls="Slider-{{ section.id }}"
      >
        <span class="svg-wrapper">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </button>
    </div>
  {%- endif -%}
</slideshow-component>

{%- if request.design_mode -%}
  <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{% schema %}
{
  "name": "TVC Slideshow",
  "tag": "section",
  "class": "section tvc-slideshow-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Desktop layout",
      "options": [
        {
          "value": "stacked",
          "label": "Full-width media + text below (white text area)"
        },
        {
          "value": "split",
          "label": "Split — text and media side by side"
        }
      ],
      "default": "stacked"
    },
    {
      "type": "header",
      "content": "Slideshow"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate slides",
      "default": false
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 9,
      "step": 2,
      "unit": "s",
      "label": "Change slides every",
      "default": 5
    },
    {
      "type": "header",
      "content": "Accessibility"
    },
    {
      "type": "text",
      "id": "accessibility_info",
      "label": "Slideshow label",
      "default": "Featured promotions slideshow"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "paragraph",
          "content": "Split layout options below apply only when this section’s Desktop layout is set to “Split — text and media side by side.” They are ignored for the stacked layout."
        },
        {
          "type": "color",
          "id": "split_background",
          "label": "Split — text panel background",
          "default": "#FFD1DC",
          "visible_if": "{{ section.settings.layout == 'split' }}"
        },
        {
          "type": "select",
          "id": "split_text_tone",
          "label": "Split — text color",
          "options": [
            {
              "value": "dark",
              "label": "Dark"
            },
            {
              "value": "light",
              "label": "Light"
            }
          ],
          "default": "dark",
          "visible_if": "{{ section.settings.layout == 'split' }}"
        },
        {
          "type": "select",
          "id": "split_media_position",
          "label": "Split — media position (desktop)",
          "options": [
            {
              "value": "right",
              "label": "Right"
            },
            {
              "value": "left",
              "label": "Left"
            }
          ],
          "default": "right",
          "visible_if": "{{ section.settings.layout == 'split' }}"
        },
        {
          "type": "header",
          "content": "Media & content"
        },
        {
          "type": "select",
          "id": "media_type",
          "label": "Media type",
          "options": [
            {
              "value": "image",
              "label": "Image"
            },
            {
              "value": "video",
              "label": "Video"
            }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "Muted and looping. Used when media type is Video."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Headline"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add descriptive text for this slide.</p>"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "info": "If blank, “Learn more” is used when a link is set."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "TVC Slideshow",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
