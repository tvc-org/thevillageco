{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-slideshow.css' | asset_url | stylesheet_tag }}
{{ 'section-tvc-slideshow.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign section_classes = 'tvc-slideshow'
  if section.settings.layout == 'stacked'
    assign section_classes = section_classes | append: ' tvc-slideshow--layout-stacked'
  else
    assign section_classes = section_classes | append: ' tvc-slideshow--layout-split'
  endif
  if section.blocks.size > 1
    assign section_classes = section_classes | append: ' tvc-slideshow--has-nav'
  endif
  if section.settings.layout == 'split' and section.blocks.size > 0
    if section.settings.split_media_position_desktop == 'left'
      assign section_classes = section_classes | append: ' tvc-slideshow--split-nav-text-right'
    else
      assign section_classes = section_classes | append: ' tvc-slideshow--split-nav-text-left'
    endif
  endif
-%}

{% if section.settings.full_width == false %}
  <div class="page-width">
{% endif %}

<slideshow-component
  class="slider-mobile-gutter {{ section_classes }}{% if section.settings.full_width %} tvc-slideshow--full-width{% else %} tvc-slideshow--contained{% endif %}"
  role="region"
  aria-roledescription="{{ 'sections.slideshow.carousel' | t }}"
  aria-label="{{ section.settings.accessibility_info | escape }}"
>
  {%- if section.blocks.size > 1 and section.settings.auto_rotate -%}
    <div class="slideshow__controls slideshow__controls--top slider-buttons">
      <button
        type="button"
        class="slider-button slider-button--prev"
        name="previous"
        aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}"
        aria-controls="Slider-{{ section.id }}"
      >
        <span class="svg-wrapper">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </button>
      <div class="slider-counter slider-counter--dots caption">
        <div class="slideshow__control-wrapper">
          {%- for block in section.blocks -%}
            <button
              type="button"
              class="slider-counter__link slider-counter__link--dots link"
              aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
              aria-controls="Slider-{{ section.id }}"
            >
              <span class="dot"></span>
            </button>
          {%- endfor -%}
        </div>
      </div>
      <button
        type="button"
        class="slider-button slider-button--next"
        name="next"
        aria-label="{{ 'sections.slideshow.next_slideshow' | t }}"
        aria-controls="Slider-{{ section.id }}"
      >
        <span class="svg-wrapper">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </button>
      <button
        type="button"
        class="slideshow__autoplay slider-button"
        aria-label="{{ 'sections.slideshow.pause_slideshow' | t }}"
      >
        <span class="svg-wrapper">
          {{- 'icon-pause.svg' | inline_asset_content -}}
        </span>
        <span class="svg-wrapper">
          {{- 'icon-play.svg' | inline_asset_content -}}
        </span>
      </button>
    </div>
  {%- endif -%}

  <div
    class="slideshow banner tvc-slideshow__slider grid grid--1-col slider slider--everywhere{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
    id="Slider-{{ section.id }}"
    aria-live="polite"
    aria-atomic="true"
    data-autoplay="{{ section.settings.auto_rotate }}"
    data-speed="{{ section.settings.change_slides_speed }}"
  >
    {%- for block in section.blocks -%}
      {%- liquid
        assign inner_classes = 'tvc-slideshow__inner'
        assign panel_classes = 'tvc-slideshow__panel'
        assign split_media_position = section.settings.split_media_position_desktop

        if split_media_position == blank
          assign split_media_position = block.settings.split_media_position
        endif

        if section.settings.layout == 'split'
          if split_media_position == 'left'
            assign inner_classes = inner_classes | append: ' tvc-slideshow__inner--media-left'
          else
            assign inner_classes = inner_classes | append: ' tvc-slideshow__inner--media-right'
          endif
          if block.settings.split_text_tone == 'light'
            assign inner_classes = inner_classes | append: ' tvc-slideshow__inner--text-light'
          else
            assign inner_classes = inner_classes | append: ' tvc-slideshow__inner--text-dark'
          endif
        else
          if block.settings.stacked_text_position == 'bottom_left'
            assign panel_classes = panel_classes | append: ' tvc-slideshow__panel--align-left'
          elsif block.settings.stacked_text_position == 'bottom_right'
            assign panel_classes = panel_classes | append: ' tvc-slideshow__panel--align-right'
          else
            assign panel_classes = panel_classes | append: ' tvc-slideshow__panel--align-center'
          endif

          if block.settings.stacked_text_in_media
            assign inner_classes = inner_classes | append: ' tvc-slideshow__inner--stacked-desktop-inmedia'
            assign panel_classes = panel_classes | append: ' tvc-slideshow__panel--stacked-desktop-inmedia'
            if block.settings.stacked_text_position == 'bottom_left'
              assign panel_classes = panel_classes | append: ' tvc-slideshow__panel--inmedia-bottom-left'
            elsif block.settings.stacked_text_position == 'bottom_right'
              assign panel_classes = panel_classes | append: ' tvc-slideshow__panel--inmedia-bottom-right'
            else
              assign panel_classes = panel_classes | append: ' tvc-slideshow__panel--inmedia-bottom-center'
            endif
            if block.settings.stacked_desktop_overlay_text_tone == 'light'
              assign panel_classes = panel_classes | append: ' tvc-slideshow__panel--tone-light'
            else
              assign panel_classes = panel_classes | append: ' tvc-slideshow__panel--tone-dark'
            endif
          endif
        endif
      -%}
      <div
        class="slideshow__slide grid__item slider__slide tvc-slideshow__slide"
        id="Slide-{{ section.id }}-{{ forloop.index }}"
        {{ block.shopify_attributes }}
        role="group"
        aria-roledescription="{{ 'sections.slideshow.slide' | t }}"
        aria-label="{{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
        tabindex="-1"
      >
        <div class="{{ inner_classes }}">
          <div class="tvc-slideshow__media">
            {%- liquid
              assign show_video = false
              if block.settings.video != blank
                assign show_video = true
              endif
            -%}
            {%- if show_video -%}
              {{
                block.settings.video
                | video_tag:
                  image_size: '2048x',
                  autoplay: true,
                  loop: true,
                  muted: true,
                  controls: false,
                  class: 'tvc-slideshow__video'
              }}
            {%- elsif block.settings.image != blank -%}
              {%- liquid
                assign desktop_image = block.settings.image
                assign mobile_image = block.settings.mobile_image
                assign height = desktop_image.width | divided_by: desktop_image.aspect_ratio | round
                assign sizes = '100vw'
                assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                assign fetch_priority = 'auto'
                if section.index == 1 and forloop.first
                  assign fetch_priority = 'high'
                endif
              -%}
              <picture>
                {%- if mobile_image != blank -%}
                  <source
                    media="(max-width: 749px)"
                    srcset="
                      {{ mobile_image | image_url: width: 375 }} 375w,
                      {{ mobile_image | image_url: width: 550 }} 550w,
                      {{ mobile_image | image_url: width: 750 }} 750w,
                      {{ mobile_image | image_url: width: 1100 }} 1100w
                    "
                    sizes="100vw"
                  >
                {%- endif -%}
                {%- if forloop.first -%}
                  {{
                    desktop_image
                    | image_url: width: 3840
                    | image_tag:
                      height: height,
                      sizes: sizes,
                      widths: widths,
                      fetchpriority: fetch_priority,
                      class: 'tvc-slideshow__image'
                  }}
                {%- else -%}
                  {{
                    desktop_image
                    | image_url: width: 3840
                    | image_tag:
                      loading: 'lazy',
                      height: height,
                      sizes: sizes,
                      widths: widths,
                      class: 'tvc-slideshow__image'
                  }}
                {%- endif -%}
              </picture>
            {%- else -%}
              {%- assign placeholder_slide = forloop.index | modulo: 2 -%}
              {%- if placeholder_slide == 1 -%}
                {{ 'hero-apparel-2' | placeholder_svg_tag: 'tvc-slideshow__placeholder placeholder-svg' }}
              {%- else -%}
                {{ 'hero-apparel-1' | placeholder_svg_tag: 'tvc-slideshow__placeholder placeholder-svg' }}
              {%- endif -%}
            {%- endif -%}

            {%- capture panel_content -%}
              {%- if block.settings.heading != blank -%}
                <h2 class="tvc-slideshow__heading h2 mt-1 mb-3 md-mb-4">
                  {{ block.settings.heading | escape | newline_to_br }}
                </h2>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="tvc-slideshow__body rte">{{ block.settings.text }}</div>
              {%- endif -%}
              {%- if block.settings.link != blank -%}
                {%- liquid
                  if block.settings.link_label != blank
                    assign link_label = block.settings.link_label
                  else
                    assign link_label = 'Learn more'
                  endif
                -%}
                <a href="{{ block.settings.link }}" class="tvc-slideshow__link cta-link mt-3 mb-5">
                  {{- link_label | escape -}}
                </a>
              {%- endif -%}
            {%- endcapture -%}
          </div>

          <div
            class="{{ panel_classes }}"
            {% if section.settings.layout == 'split' %}
              style="background-color: {{ block.settings.split_background }};"
            {% endif %}
          >
            {{ panel_content }}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 and section.settings.auto_rotate == false -%}
    <div class="slideshow__controls slider-buttons">
      <button
        type="button"
        class="slider-button slider-button--prev"
        name="previous"
        aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}"
        aria-controls="Slider-{{ section.id }}"
      >
        <span class="svg-wrapper">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </button>
      <div class="slider-counter slider-counter--dots caption">
        <div class="slideshow__control-wrapper">
          {%- for block in section.blocks -%}
            <button
              type="button"
              class="slider-counter__link slider-counter__link--dots link"
              aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
              aria-controls="Slider-{{ section.id }}"
            >
              <span class="dot"></span>
            </button>
          {%- endfor -%}
        </div>
      </div>
      <button
        type="button"
        class="slider-button slider-button--next"
        name="next"
        aria-label="{{ 'sections.slideshow.next_slideshow' | t }}"
        aria-controls="Slider-{{ section.id }}"
      >
        <span class="svg-wrapper">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </button>
    </div>
  {%- endif -%}
</slideshow-component>

{% if section.settings.full_width == false %}
  </div>
{% endif %}

{%- if request.design_mode -%}
  <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{% schema %}
{
  "name": "TVC Slideshow",
  "tag": "section",
  "class": "section tvc-slideshow-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Desktop layout",
      "options": [
        {
          "value": "stacked",
          "label": "Full-width media + text below (white text area)"
        },
        {
          "value": "split",
          "label": "Split — text and media side by side"
        }
      ],
      "default": "stacked"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": true
    },
    {
      "type": "select",
      "id": "split_media_position_desktop",
      "label": "Split — media position (desktop)",
      "options": [
        {
          "value": "right",
          "label": "Right"
        },
        {
          "value": "left",
          "label": "Left"
        }
      ],
      "default": "right",
      "visible_if": "{{ section.settings.layout == 'split' }}"
    },
    {
      "type": "header",
      "content": "Slideshow"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate slides",
      "default": false
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 9,
      "step": 2,
      "unit": "s",
      "label": "Change slides every",
      "default": 5
    },
    {
      "type": "header",
      "content": "Accessibility"
    },
    {
      "type": "text",
      "id": "accessibility_info",
      "label": "Slideshow label",
      "default": "Featured promotions slideshow"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "paragraph",
          "content": "Split layout options below apply only when this section’s Desktop layout is set to “Split — text and media side by side.” They are ignored for the stacked layout."
        },
        {
          "type": "color",
          "id": "split_background",
          "label": "Split — text panel background",
          "default": "#FFD1DC",
          "visible_if": "{{ section.settings.layout == 'split' }}"
        },
        {
          "type": "select",
          "id": "split_text_tone",
          "label": "Split — text color",
          "options": [
            {
              "value": "dark",
              "label": "Dark"
            },
            {
              "value": "light",
              "label": "Light"
            }
          ],
          "default": "dark",
          "visible_if": "{{ section.settings.layout == 'split' }}"
        },
        {
          "type": "paragraph",
          "content": "If a video is added, it automatically overrides image and mobile image for this slide."
        },
        {
          "type": "header",
          "content": "Media & content"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image",
          "info": "Optional. Used for image slides on screens below 750px."
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "Muted and looping. Overrides image and mobile image when set."
        },
        {
          "type": "textarea",
          "id": "heading",
          "label": "Heading",
          "default": "Headline"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add descriptive text for this slide.</p>"
        },
        {
          "type": "checkbox",
          "id": "stacked_text_in_media",
          "label": "Full-width media — place text over media (desktop)",
          "info": "On screens below 960px, text always appears below the image with dark text on a white panel.",
          "default": false,
          "visible_if": "{{ section.settings.layout == 'stacked' }}"
        },
        {
          "type": "select",
          "id": "stacked_desktop_overlay_text_tone",
          "label": "Full-width media — text color over media (desktop)",
          "options": [
            {
              "value": "dark",
              "label": "Dark"
            },
            {
              "value": "light",
              "label": "Light"
            }
          ],
          "default": "dark",
          "visible_if": "{{ section.settings.layout == 'stacked' and block.settings.stacked_text_in_media == true }}"
        },
        {
          "type": "select",
          "id": "stacked_text_position",
          "label": "Full-width media — text position",
          "info": "Controls left/center/right placement when text is over media (desktop), and text alignment when text is below media.",
          "options": [
            {
              "value": "bottom_left",
              "label": "Bottom left"
            },
            {
              "value": "bottom_center",
              "label": "Bottom center"
            },
            {
              "value": "bottom_right",
              "label": "Bottom right"
            }
          ],
          "default": "bottom_center",
          "visible_if": "{{ section.settings.layout == 'stacked' }}"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "info": "If blank, “Learn more” is used when a link is set."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "TVC Slideshow",
      "blocks": [
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
