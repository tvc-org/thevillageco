{{ 'component-rating.css' | asset_url | stylesheet_tag }}
{{ 'section-tvc-featured-review.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign rating_value = section.settings.rating | default: 5 | plus: 0
  assign rating_max = 5
  assign featured_product = section.settings.product
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="tvc-featured-review color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding isolate">
    <div class="tvc-featured-review__inner{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {%- if section.settings.eyebrow != blank -%}
        <p class="tvc-featured-review__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      <div class="tvc-featured-review__rating">
        <div
          class="rating"
          role="img"
          aria-label="{{ 'accessibility.star_reviews_info' | t: rating_value: rating_value, rating_max: rating_max }}"
        >
          <span
            aria-hidden="true"
            class="rating-star"
            style="--rating: {{ rating_value }}; --rating-max: {{ rating_max }}; --rating-decimal: 0;"
          ></span>
        </div>
        <p class="rating-text caption">
          <span aria-hidden="true">{{ rating_value }} / {{ rating_max }}</span>
        </p>
      </div>

      {%- if section.settings.title != blank -%}
        <h2 class="tvc-featured-review__title inline-richtext h2">{{ section.settings.title }}</h2>
      {%- endif -%}

      {%- if section.settings.review_text != blank -%}
        <div class="tvc-featured-review__body rte">{{ section.settings.review_text }}</div>
      {%- endif -%}

      {%- if featured_product != blank -%}
        <p class="tvc-featured-review__attribution caption">
          {{ 'sections.tvc_featured_review.attribution_prefix' | t }}
          <a href="{{ featured_product.url }}">{{ featured_product.title | escape }}</a>
        </p>
      {%- endif -%}

      <hr class="tvc-featured-review__rule" aria-hidden="true">
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.tvc-featured-review.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.tvc-featured-review.settings.yotpo_info.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.tvc-featured-review.settings.eyebrow.label",
      "default": "Featured Review"
    },
    {
      "type": "select",
      "id": "rating",
      "label": "t:sections.tvc-featured-review.settings.rating.label",
      "default": "5",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ]
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "t:sections.tvc-featured-review.settings.title.label",
      "default": "Write a headline for your review"
    },
    {
      "type": "richtext",
      "id": "review_text",
      "label": "t:sections.tvc-featured-review.settings.review_text.label",
      "default": "<p>Share what customers said about your product.</p>"
    },
    {
      "type": "product",
      "id": "product",
      "label": "t:sections.tvc-featured-review.settings.product.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "t:sections.tvc-featured-review.presets.name"
    }
  ]
}
{% endschema %}
