{{ 'section-tvc-shared.css' | asset_url | stylesheet_tag }}
{{ 'section-tvc-home-intro.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign tvc_hi_image = section.settings.image
  assign tvc_hi_callout_blocks = section.blocks | where: 'type', 'callout'
-%}

<div class="tvc-home-intro">
  <div class="tvc-home-intro__grid">
    <div class="tvc-home-intro__content">
      <div
        class="tvc-home-intro__content-inner{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        {% if settings.animations_reveal_on_scroll %}
          data-cascade
          style="--animation-order: 1;"
        {% endif %}
      >
        {%- if section.settings.pre_title != blank -%}
          <p class="tvc-pretitle">{{ section.settings.pre_title | escape }}</p>
        {%- endif -%}

        {%- if section.settings.title != blank -%}
          <h2 class="tvc-home-intro__title mt-2 mb-4 lg-mb-6">{{ section.settings.title }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="tvc-home-intro__body rte">{{ section.settings.text }}</div>
        {%- endif -%}

        {%- if tvc_hi_callout_blocks.size > 0 -%}
          <ul class="tvc-home-intro__callouts" role="list">
            {%- for block in tvc_hi_callout_blocks -%}
              <li
                class="tvc-home-intro__callout{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {{ block.shopify_attributes }}
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index | plus: 1 }};"
                {% endif %}
              >
                {%- if block.settings.title != blank -%}
                  <span class="tvc-home-intro__callout-title mb-4 lg-mb-5">{{ block.settings.title | escape }}</span>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <span class="tvc-home-intro__callout-text mt-0">{{ block.settings.text | escape }}</span>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>

    {%- if tvc_hi_image != blank -%}
      <div
        class="tvc-home-intro__media{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        {% if settings.animations_reveal_on_scroll %}
          data-cascade
          style="--animation-order: {{ tvc_hi_callout_blocks.size | plus: 2 }};"
        {% endif %}
      >
        {%- liquid
          assign tvc_hi_alt = tvc_hi_image.alt | default: section.settings.pre_title
          if tvc_hi_alt == blank and section.settings.title != blank
            assign tvc_hi_alt = section.settings.title | strip_html
          endif
          assign tvc_hi_widths = '750, 990, 1200, 1500, 1800, 2200'
        -%}
        {{
          tvc_hi_image
          | image_url: width: 2200
          | image_tag:
            loading: 'lazy',
            widths: tvc_hi_widths,
            sizes: '(min-width: 960px) 50vw, 100vw',
            class: 'tvc-home-intro__image',
            alt: tvc_hi_alt
        }}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.tvc-home-intro.name",
  "tag": "section",
  "class": "section section-tvc-home-intro",
  "max_blocks": 4,
  "enabled_on": {
    "templates": ["index"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.tvc-home-intro.settings.header_content.content"
    },
    {
      "type": "text",
      "id": "pre_title",
      "label": "t:sections.tvc-home-intro.settings.pre_title.label",
      "default": "Trusted personal care — since 1991"
    },
    {
      "type": "html",
      "id": "title",
      "label": "t:sections.tvc-home-intro.settings.title.label",
      "info": "t:sections.tvc-home-intro.settings.title.info",
      "default": "Built on trust.\n<span class=\"tvc-title-accent\">Made for</span>\neveryday life."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:sections.tvc-home-intro.settings.text.label",
      "default": "<p>For over 30 years, we've been creating personal care products that help people feel better—body and mind. From a quiet soak to laughter-filled bath time with the kids, our products are designed for moments that restore, relax, and reconnect.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.tvc-home-intro.settings.image.label"
    }
  ],
  "blocks": [
    {
      "type": "callout",
      "name": "t:sections.tvc-home-intro.blocks.callout.name",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.tvc-home-intro.blocks.callout.settings.title.label",
          "default": "30+"
        },
        {
          "type": "text",
          "id": "text",
          "label": "t:sections.tvc-home-intro.blocks.callout.settings.text.label",
          "default": "Years of innovation"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.tvc-home-intro.presets.name",
      "category": "Homepage",
      "blocks": [
        {
          "type": "callout",
          "settings": {
            "title": "30+",
            "text": "Years of innovation"
          }
        },
        {
          "type": "callout",
          "settings": {
            "title": "6",
            "text": "Beloved brands"
          }
        },
        {
          "type": "callout",
          "settings": {
            "title": "365",
            "text": "Days / year feeling good"
          }
        },
        {
          "type": "callout",
          "settings": {
            "title": "∞",
            "text": "Moments restored"
          }
        }
      ]
    }
  ]
}
{% endschema %}
