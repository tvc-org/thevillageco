{% comment %}
  Klaviyo Back in Stock — loads hosted onsite.js then enables legacy BIS.
  @param section_id {String}
{% endcomment %}
<script>
  (function () {
    var onsiteUrl = 'https://a.klaviyo.com/media/js/onsite/onsite.js';

    function enableBackInStock() {
      var klaviyo = window.klaviyo || [];
      window.klaviyo = klaviyo;
      klaviyo.init({
        account: {{ settings.klaviyo_company_id | default: 'UT3Uie' | json }},
        platform: 'shopify',
        exclude_on_tags: 'holiday',
      });
      klaviyo.enable('backinstock', {
        trigger: {
          product_page_text: 'Notify When Available',
          product_page_class: 'btn',
          product_page_text_align: 'center',
          product_page_margin: '0px',
          replace_anchor: false,
          alternate_anchor: 'ProductNotify-{{ section_id }}',
        },
        modal: {
          headline: '{product_name}',
          body_content: 'Register to receive a notification when this item comes back in stock.',
          email_field_label: 'Email',
          button_label: 'Notify me when available',
          subscription_success_label: "You're in! We'll let you know when it's back.",
          footer_content: '',
          additional_styles: '',
          drop_background_color: '#000',
          background_color: '#fff',
          text_color: '#222',
          button_text_color: '#fff',
          button_background_color: '#439fdb',
          close_button_color: '#ccc',
          error_background_color: '#fcd6d7',
          error_text_color: '#C72E2F',
          success_background_color: '#d3efcd',
          success_text_color: '#1B9500',
        },
      });
      document.dispatchEvent(new CustomEvent('klaviyo:backinstock:enabled'));
    }

    if (window.__klaviyoOnsiteLoaded) {
      enableBackInStock();
      return;
    }

    var script = document.createElement('script');
    script.async = true;
    script.src = onsiteUrl;
    script.onload = function () {
      window.__klaviyoOnsiteLoaded = true;
      enableBackInStock();
    };
    document.head.appendChild(script);
  })();
</script>
