{% comment %}
============= Warning: DO NOT EDIT THIS FILE UNLESS YOU KNOW WHAT YOU ARE DOING! =============

Cross Sell "custom theme" markup. Referenced from layout/theme.liquid on product pages.

Support: https://help.csell.co

============= Warning: DO NOT EDIT THIS FILE UNLESS YOU KNOW WHAT YOU ARE DOING! =============
{% endcomment %}
{%- assign plp_quickshop = plp_quickshop | default: true -%}
{%- assign tvc_xs_preorder_tag = settings.product_preorder_message | default: '' | strip -%}
{%- capture tvc_xs_cross_sell_spinner -%}
  {%- render 'loading-spinner' -%}
{%- endcapture -%}
<script>
window.xsellCustom = window.xsellCustom || {};
window.xsellCustom.theme_settings = window.xsellCustom.theme_settings || {};
window.xsellCustom.quickAddSpinnerHtml = {{ tvc_xs_cross_sell_spinner | strip | json }};
window.xsellCustom.buildxsellsoutput = function(xsellitems, numproducts) {
    var tvcXsPreorderTag = {{ tvc_xs_preorder_tag | json }};
    /* Iterate every object xsellLib passes. numproducts is only a cap from the app; when the
       array is longer than numproducts, still render all entries (avoids accidental under-count). */
    var xsLen = xsellitems && typeof xsellitems.length === 'number' ? xsellitems.length : 0;

    var xsmustbeavailable = xsellSettings.xsmustbeavailable;
    var xshideifincart = xsellSettings.xshideifincart;
    var xsdisplaycompareatprice = xsellSettings.xsdisplaycompareatprice;
    var xsdisplaysalebadge = xsellSettings.xsdisplaysalebadge;
    var xsdisplaypricevarieslabel = xsellSettings.xsdisplaypricevarieslabel;
    var xsdisplayvendor = xsellSettings.xsdisplayvendor;
    var xsimagesize = 'large';
    var xsvendoroutput = '';
    var xspricevarieslabel = '';
    var xscompareatprice = '';
    var xscompareatpricestring = '';
    var xssalepricestring = '';
    var xspriceoutput = '';
    var xssalebadge = '<span class="product-badge"><span>Sale</span></span>';
    var xssalebadgeoutput = '';
    var xspreorderbadgeoutput = '';
    var xssoldout = '';
    var xsquickshop = '';
    var saleclass = ' xs-sale';
    var fromlabel = '<em>from</em>';
    var xsprice = '';

    for (var x = 0; x < xsLen; x++) {
        var xsproductdata = xsellitems[x];
        if (!xsproductdata) {
            continue;
        }
        var xsProductTags = Array.isArray(xsproductdata.tags) ? xsproductdata.tags : [];

        var imgCount = xsproductdata.images && typeof xsproductdata.images.length === 'number'
            ? xsproductdata.images.length
            : 0;
        if (imgCount > 1) {
            var csimage = xsellLib.productimageurls(xsproductdata.images[0]);
            var csimagetwo = xsellLib.productimageurls(xsproductdata.images[1]);
        } else if (imgCount === 1) {
            var csimage = xsellLib.productimageurls(xsproductdata.images[0]);
            var csimagetwo = csimage;
        } else {
            var csimage = 'https://cdn.shopify.com/s/images/admin/no-image-' + xsimagesize + '.gif';
            var csimagetwo = csimage;
        }
        if (xsdisplayvendor) {
            xsvendoroutput = '<div class="xs-vendor-name"><a href="' + xsproductdata.url + '">' + xsproductdata.vendor + '</a></div>';
        }

        xsprice = xsellLib.xsformatMoney(xsproductdata.price, '{{ shop.money_format }}');
        xspriceMin = xsellLib.xsformatMoney(xsproductdata.price_min, '{{ shop.money_format }}');
        xspriceMax = xsellLib.xsformatMoney(xsproductdata.price_max, '{{ shop.money_format }}');
        if (xsdisplaypricevarieslabel) {
            if (xsproductdata.price_varies) {
                xspricevarieslabel = 'Starting at: ';
            } else {
                xspricevarieslabel = '';
            }
        }

        if (xsproductdata.compare_at_price > xsproductdata.price) {
            xscompareatprice = xsellLib.xsformatMoney(xsproductdata.compare_at_price, '{{ shop.money_format }}');
            xspriceoutput  = '<div class="price-box  has-special">';
            xspriceoutput +=    '<span class="product-price-x" itemprop="price-x" content="' + xsproductdata.price/100 + '">' + xsprice + '</span>';
            xspriceoutput +=    '<span class="product-compare-price">' + xscompareatprice + '</span>';
            xspriceoutput += '</div>';
        } else if(xsproductdata.price_varies) {
            xspriceoutput = '<div class="price-box"><span class="product-price-x" itemprop="price-x" content="' + xsproductdata.price/100 + '">' + xspriceMin + ' - ' + xspriceMax + '</span></div>';
        } else {
            xspriceoutput = '<div class="price-box"><span class="product-price-x" itemprop="price-x" content="' + xsproductdata.price/100 + '">' + xsprice + '</span></div>';
        }

        if (xsdisplaysalebadge) {
            if (xsproductdata.compare_at_price > xsproductdata.price) {
                xssalebadgeoutput = xssalebadge;
            } else {
                xssalebadgeoutput = '';
            }
        }

        {
            var xsProductBadgeTag = xsProductTags.find(function(tag){
                return typeof tag === 'string' && tag.indexOf('badge:') !== -1;
            });
            if (xsProductBadgeTag) {
                xssalebadgeoutput = '<span class="product-badge"><span>' + xsProductBadgeTag.replace("badge:", "") + '</span></span>';
            } else {
                xssalebadgeoutput = '';
            }
        }

        xspreorderbadgeoutput = '';
        if (tvcXsPreorderTag && String(tvcXsPreorderTag).length > 0) {
            var xsProductPreorderTag = xsProductTags.find(function(tag){
                return typeof tag === 'string' && tag.indexOf(tvcXsPreorderTag) !== -1;
            });
            if (xsProductPreorderTag) {
                xspreorderbadgeoutput = '<span class="product-badge"><span>' + {{ 'products.product.pre_order' | t | json }} + '</span></span>';
            }
        }

        var htmlSecondaryImg = '';
        if (xsellLib.userSettings.hoover_secondary_image){
          htmlSecondaryImg = '<img class="product-image alt" src="' + csimagetwo + '" />';
        }

        if (xsproductdata.available) {
            xssoldout = '';
        } else {
            xssoldout = '<p class="out-of-stock">' + "{{ 'products.product.sold_out' | t }}" + '</p>';
        }

        {% if plp_quickshop %}
        var qaModal = (window.xsellCustom && window.xsellCustom.crossSellQuickAddModal) || '';
        var qaSpinner = (window.xsellCustom && window.xsellCustom.quickAddSpinnerHtml) || '<div class="loading__spinner hidden"></div>';
        if (xsproductdata.available) {
            var safeXsUrl = String(xsproductdata.url || '').replace(/&/g, '&amp;').replace(/"/g, '&quot;');
            if (qaModal) {
                var safeModal = String(qaModal).replace(/&/g, '&amp;').replace(/"/g, '&quot;');
                xsquickshop =
                    '<modal-opener class="tvc-cross-sell-quick-add-opener" data-modal="' +
                    safeModal +
                    '">' +
                    '<button type="button" class="quick-shop-trigger" aria-haspopup="dialog" data-product-url="' +
                    safeXsUrl +
                    '">Quick Shop' +
                    qaSpinner +
                    '</button></modal-opener>';
            } else {
                xsquickshop =
                    '<a class="quick-shop-trigger" href="' +
                    safeXsUrl +
                    '">Quick Shop</a>';
            }
        } else {
            xsquickshop = '';
        }
        {% endif %}

        xsellLib.xselloutput += '<div class="item" data-xsorder="' + xsproductdata["order"] + '">';
        xsellLib.xselloutput +=     '<div class="product-image-wrapper">';
        xsellLib.xselloutput +=         '<a href="' + xsproductdata.url + '">';
        xsellLib.xselloutput +=             '<img class="product-image" src="' + csimage + '" />';
        xsellLib.xselloutput +=             htmlSecondaryImg;
        xsellLib.xselloutput +=         '</a>';
        xsellLib.xselloutput +=         xssalebadgeoutput;
        xsellLib.xselloutput +=         xspreorderbadgeoutput;
        xsellLib.xselloutput +=         xsquickshop;
        xsellLib.xselloutput +=     '</div>';
        xsellLib.xselloutput +=     '<div class="product-info-wrapper">';
        xsellLib.xselloutput +=         '<p class="product-name">' + xsproductdata.title + '</p>';
        xsellLib.xselloutput +=         xspriceoutput;
        xsellLib.xselloutput +=         xssoldout;
        xsellLib.xselloutput +=     '</div>';
        xsellLib.xselloutput += '</div>';
    }

    if (xsellLib.xselloutput != '') {
        var innerHtml = '<div class="crosssell-text"><h3 class="title">' + xsellLib.settings.xstitle + '</h3></div><div class="collection-products items">' + xsellLib.xselloutput + '</div>';
        if (document.getElementById('cross-sell')) {
            var xsellDiv = document.createElement('div');
            xsellDiv.innerHTML = innerHtml;
            document.getElementById('cross-sell').appendChild(xsellDiv);
        }
        if (document.getElementById('cross-sell-cart')) {
            var xsellDivCart = document.createElement('div');
            xsellDivCart.innerHTML = innerHtml;
            document.getElementById('cross-sell-cart').appendChild(xsellDivCart);
        }
        if (document.getElementById('cross-sell-minicart')) {
            var xsellDivMini = document.createElement('div');
            xsellDivMini.innerHTML = innerHtml;
            document.getElementById('cross-sell-minicart').appendChild(xsellDivMini);
        }
    } else {
        var hasCrossSellDiv = document.getElementsByClassName('has-cross-sell');
        if (hasCrossSellDiv.length) {
            for (var i = 0; i < hasCrossSellDiv.length; i++) {
                hasCrossSellDiv[i].classList.remove('has-cross-sell');
            }
        }
    }
}
</script>
