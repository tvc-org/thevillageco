{%- comment -%}
  PDP Cross Sell block: fixed padding + color-scheme-1, scoped CSS for #cross-sell (vendor app + cross-sell-custom).
  Optional: ordered handles from productDetails.crosssell to pad up to 3 cards when the app omits a slot.
  Params: product, section, block.
{%- endcomment -%}

{%- liquid
  assign tvc_xs_h = ''
  assign tvc_xs_mf = product.metafields.productDetails.crosssell
  if tvc_xs_mf == blank
    assign tvc_xs_mf = product.metafields['productDetails'].crosssell
  endif
  if tvc_xs_mf != blank
    assign tvc_xs_raw = tvc_xs_mf | metafield_text | strip
    if tvc_xs_raw == blank and tvc_xs_mf.value != blank
      assign tvc_xs_raw = tvc_xs_mf.value | append: '' | strip
    endif
    if tvc_xs_raw != blank
      assign tvc_xs_arr = tvc_xs_raw | parse_json
      if tvc_xs_arr != blank
        assign tvc_xs_r0 = tvc_xs_arr | first
        assign tvc_xs_from_rows = false
        if tvc_xs_r0 != blank
          assign tvc_h0 = tvc_xs_r0.handle | default: tvc_xs_r0['handle'] | strip
          if tvc_h0 != blank
            assign tvc_xs_from_rows = true
          endif
        endif
        if tvc_xs_from_rows
          for row in tvc_xs_arr
            assign hh = row.handle | default: row['handle'] | strip
            if hh == blank and row.url != blank and row.url contains '/products/'
              assign hh = row.url | split: '/products/' | last | split: '?' | first | split: '#' | first | split: '/' | first | strip
            endif
            unless hh == blank
              assign tvc_xs_h = tvc_xs_h | append: hh | append: '||'
            endunless
          endfor
        else
          assign tvc_xs_delim = '"' | append: 'handle' | append: '":"'
          assign tvc_xs_norm = tvc_xs_raw | replace: '"handle" : "', tvc_xs_delim
          assign tvc_xs_bits = tvc_xs_norm | split: tvc_xs_delim
          for bit in tvc_xs_bits
            unless forloop.first
              assign hh = bit | split: '"' | first | strip
              unless hh == blank
                assign tvc_xs_h = tvc_xs_h | append: hh | append: '||'
              endunless
            endunless
          endfor
        endif
      endif
    endif
  endif
  assign tvc_xs_handles = tvc_xs_h | split: '||' | compact
-%}

{%- style -%}
  .tvc-cross-sell-addons.tvc-cross-sell-pad {
    padding-top: 18px;
    padding-bottom: 18px;
  }
  @media screen and (min-width: 750px) {
    .tvc-cross-sell-addons.tvc-cross-sell-pad {
      padding-top: 24px;
      padding-bottom: 24px;
    }
  }

  /* Scoped to .tvc-cross-sell-addons so cart/minicart #cross-sell-cart targets stay unchanged */
  .tvc-cross-sell-addons #cross-sell > div {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .tvc-cross-sell-addons #cross-sell .crosssell-text {
    width: 100%;
    text-align: center;
  }

  .tvc-cross-sell-addons #cross-sell .crosssell-text .title {
    margin: 0 0 1.25rem;
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    font-size: calc(var(--font-heading-scale) * 2rem);
    line-height: 1.2;
    letter-spacing: calc(var(--font-heading-scale) * 0.06rem);
  }

  .tvc-cross-sell-addons #cross-sell .collection-products.items {
    display: flex;
    flex-wrap: nowrap;
    justify-content: center;
    align-items: flex-start;
    width: 100%;
    max-width: 100%;
    margin: 0;
    padding: 0;
    list-style: none;
    gap: 0;
  }

  .tvc-cross-sell-addons #cross-sell .collection-products.items .item {
    flex: 1;
    min-width: 0;
    padding: 0 clamp(0.75rem, 3vw, 1.5rem);
    box-sizing: border-box;
  }

  .tvc-cross-sell-addons #cross-sell .collection-products.items .item:nth-of-type(n + 4) {
    display: none;
  }

  .tvc-cross-sell-addons #cross-sell .product-image-wrapper {
    position: relative;
    margin: 0 auto 1rem;
    width: 100%;
    max-width: 220px;
    aspect-ratio: 1 / 1;
  }

  .tvc-cross-sell-addons #cross-sell .product-image-wrapper > a {
    display: block;
    line-height: 0;
    position: relative;
    width: 100%;
    height: 100%;
  }

  .tvc-cross-sell-addons #cross-sell .product-image-wrapper img.product-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    vertical-align: middle;
  }

  .tvc-cross-sell-addons #cross-sell .product-image-wrapper img.product-image.alt {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }

  .tvc-cross-sell-addons #cross-sell .product-image-wrapper > a:hover img.product-image.alt {
    opacity: 1;
  }

  .tvc-cross-sell-addons #cross-sell .product-image-wrapper .product-badge {
    display: none;
  }

  /* Quick Shop: Dawn modal-opener + bar (pointer-events on wrapper so the bar stays clickable) */
  .tvc-cross-sell-addons #cross-sell .item .tvc-cross-sell-quick-add-opener {
    display: block;
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 3;
    pointer-events: none;
  }

  .tvc-cross-sell-addons #cross-sell .item .tvc-cross-sell-quick-add-opener .quick-shop-trigger {
    position: relative;
    width: 100%;
    margin: 0;
    padding: 0.65rem 0.5rem;
    border: 0;
    border-radius: 0;
    cursor: pointer;
    text-align: center;
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: 600;
    font-size: calc(var(--font-body-scale) * 1.15rem);
    line-height: 1.2;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    background-color: #006bb6;
    box-sizing: border-box;
    transition: opacity 0.35s ease, transform 0.35s ease;
    text-decoration: none;
    display: block;
  }

  .tvc-cross-sell-addons #cross-sell .item .tvc-cross-sell-quick-add-opener .quick-shop-trigger .loading__spinner {
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
  }

  @media (hover: hover) and (pointer: fine) {
    .tvc-cross-sell-addons #cross-sell .item .tvc-cross-sell-quick-add-opener .quick-shop-trigger {
      opacity: 0;
    }

    .tvc-cross-sell-addons #cross-sell .item:hover .tvc-cross-sell-quick-add-opener {
      pointer-events: auto;
    }

    .tvc-cross-sell-addons #cross-sell .item:hover .tvc-cross-sell-quick-add-opener .quick-shop-trigger {
      opacity: 1;
    }
  }

  @media (hover: none), (pointer: coarse) {
    .tvc-cross-sell-addons #cross-sell .item .tvc-cross-sell-quick-add-opener {
      pointer-events: auto;
    }

    .tvc-cross-sell-addons #cross-sell .item .tvc-cross-sell-quick-add-opener .quick-shop-trigger {
      opacity: 1;
    }
  }

  .tvc-cross-sell-addons #cross-sell .product-info-wrapper {
    text-align: center;
    max-width: 220px;
    margin-left: auto;
    margin-right: auto;
  }

  .tvc-cross-sell-addons #cross-sell .product-info-wrapper .product-name {
    margin: 0 0 0.35rem;
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    font-size: calc(var(--font-heading-scale) * 1.25rem);
    line-height: 1.25;
  }

  .tvc-cross-sell-addons #cross-sell .product-info-wrapper .price-box {
    display: block;
    margin: 0 auto 0.25rem;
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: 400;
    font-size: calc(var(--font-body-scale) * 1.4rem);
    line-height: 1.35;
    letter-spacing: 0.02em;
  }

  .tvc-cross-sell-addons #cross-sell .product-info-wrapper .price-box .product-price-x {
    font-size: inherit;
    font-weight: 400;
    line-height: inherit;
    margin: 0;
  }

  .tvc-cross-sell-addons #cross-sell .product-info-wrapper .price-box.h2,
  .tvc-cross-sell-addons #cross-sell .product-info-wrapper .price-box .h2 {
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
  }

  .tvc-cross-sell-addons #cross-sell .product-info-wrapper .price-box .product-compare-price {
    display: inline-block;
    margin-left: 0.35rem;
    color: rgba(var(--color-foreground), 0.75);
    font-size: 0.92em;
  }

  .tvc-cross-sell-addons #cross-sell .product-info-wrapper .out-of-stock {
    margin: 0.25rem 0 0;
    font-size: calc(var(--font-body-scale) * 1.3rem);
  }

  @media screen and (max-width: 749px) {
    .tvc-cross-sell-addons #cross-sell .collection-products.items {
      flex-wrap: wrap;
      justify-content: center;
    }

    .tvc-cross-sell-addons #cross-sell .collection-products.items .item {
      flex: 1 1 100%;
      max-width: 100%;
      padding: 0 0 1.5rem;
    }

    .tvc-cross-sell-addons #cross-sell .product-image-wrapper {
      max-width: 280px;
    }
  }
{%- endstyle -%}

<script>
  window.xsellCustom = window.xsellCustom || {};
  window.xsellCustom.crossSellQuickAddModal = '#QuickAdd-{{ block.id }}';
</script>

<div
  id="TvcCrossSell-{{ block.id }}"
  class="tvc-cross-sell-addons color-scheme-1 gradient tvc-cross-sell-pad"
  {{ block.shopify_attributes }}
>
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  {%- if shop.metafields.shopCrosssell.settings != null -%}
    {% render 'cross-sell', product: product %}
  {%- endif -%}
  <quick-add-modal
    id="QuickAdd-{{ block.id }}"
    class="quick-add-modal color-scheme-1"
  >
    <div
      role="dialog"
      aria-label="{{ 'products.product.choose_options' | t | escape }}"
      aria-modal="true"
      class="quick-add-modal__content global-settings-popup"
      tabindex="-1"
    >
      <button
        id="ModalClose-{{ block.id }}"
        type="button"
        class="quick-add-modal__toggle"
        aria-label="{{ 'accessibility.close' | t }}"
      >
        {{- 'icon-close.svg' | inline_asset_content -}}
      </button>
      <div id="QuickAddInfo-{{ block.id }}" class="quick-add-modal__content-info"></div>
    </div>
  </quick-add-modal>
</div>

{%- if tvc_xs_handles.size > 0 -%}
  <script>
    (function () {
      var maxSlots = 3;
      var handles = {{ tvc_xs_handles | json }};
      var currentHandle = {{ product.handle | json }};
      var moneyFormat = {{ shop.money_format | json }};
      var soldOutLabel = {{ 'products.product.sold_out' | t | json }};

      function formatMoney(cents) {
        cents = Math.round(Number(cents) || 0);
        var tpl = moneyFormat || '${{amount}}';
        var amount = (cents / 100).toFixed(2);
        if (typeof Shopify !== 'undefined' && typeof Shopify.formatMoney === 'function') {
          try {
            return Shopify.formatMoney(cents, tpl);
          } catch (e) {}
        }
        return tpl
          .replace(/\{\{\s*amount\s*\}\}/gi, amount)
          .replace(/\{\{\s*amount_no_decimals\s*\}\}/gi, String(Math.round(cents / 100)));
      }

      function productUrl(handle) {
        return '/products/' + encodeURIComponent(handle);
      }

      function primaryImageSrc(p) {
        if (p.featured_image) {
          if (typeof p.featured_image === 'string') return p.featured_image;
          if (p.featured_image.src) return p.featured_image.src;
        }
        if (p.image) {
          if (typeof p.image === 'string') return p.image;
          if (p.image.src) return p.image.src;
        }
        if (p.images && p.images.length) {
          var im = p.images[0];
          if (typeof im === 'string') return im;
          if (im && im.src) return im.src;
        }
        return '';
      }

      function escapeHtml(s) {
        return String(s == null ? '' : s)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
      }

      function collectHandles(container) {
        var set = {};
        container.querySelectorAll('a[href*="/products/"]').forEach(function (a) {
          var m = a.getAttribute('href').match(/\/products\/([^/?#]+)/);
          if (m && m[1]) {
            try {
              set[decodeURIComponent(m[1])] = true;
            } catch (e) {
              set[m[1]] = true;
            }
          }
        });
        return set;
      }

      function itemCount(container) {
        return container.querySelectorAll(':scope > .item').length;
      }

      function appendItem(container, p, order) {
        var url = productUrl(p.handle);
        var img = primaryImageSrc(p);
        if (img && img.indexOf('//') === 0) img = 'https:' + img;
        var v = p.variants && p.variants[0];
        var price = v && typeof v.price !== 'undefined' ? v.price : p.price;
        var cmp = v && typeof v.compare_at_price !== 'undefined' ? v.compare_at_price : p.compare_at_price;
        var minP = typeof p.price_min !== 'undefined' ? p.price_min : price;
        var maxP = typeof p.price_max !== 'undefined' ? p.price_max : price;
        var priceHtml = '';
        if (cmp && Number(cmp) > Number(price)) {
          priceHtml =
            '<div class="price-box  has-special"><span class="product-price-x">' +
            formatMoney(price) +
            '</span><span class="product-compare-price">' +
            formatMoney(cmp) +
            '</span></div>';
        } else if (minP !== maxP) {
          priceHtml =
            '<div class="price-box"><span class="product-price-x">' +
            formatMoney(minP) +
            ' - ' +
            formatMoney(maxP) +
            '</span></div>';
        } else {
          priceHtml = '<div class="price-box"><span class="product-price-x">' + formatMoney(price) + '</span></div>';
        }
        var sold = p.available ? '' : '<p class="out-of-stock">' + escapeHtml(soldOutLabel) + '</p>';
        var productUrlAttr = escapeHtml(p.url || url);
        var qaModalSel =
          window.xsellCustom && window.xsellCustom.crossSellQuickAddModal
            ? String(window.xsellCustom.crossSellQuickAddModal)
            : '';
        var qaSpin =
          window.xsellCustom && window.xsellCustom.quickAddSpinnerHtml
            ? String(window.xsellCustom.quickAddSpinnerHtml)
            : '<div class="loading__spinner hidden"></div>';
        var qsBtn = '';
        if (p.available && qaModalSel) {
          qsBtn =
            '<modal-opener class="tvc-cross-sell-quick-add-opener" data-modal="' +
            escapeHtml(qaModalSel) +
            '"><button type="button" class="quick-shop-trigger" aria-haspopup="dialog" data-product-url="' +
            productUrlAttr +
            '">Quick Shop' +
            qaSpin +
            '</button></modal-opener>';
        } else if (p.available) {
          qsBtn =
            '<a class="quick-shop-trigger" href="' + productUrlAttr + '">Quick Shop</a>';
        }
        var wrap = document.createElement('div');
        wrap.className = 'item';
        wrap.setAttribute('data-xsorder', String(order));
        wrap.innerHTML =
          '<div class="product-image-wrapper"><a href="' +
          escapeHtml(url) +
          '">' +
          (img
            ? '<img class="product-image" src="' + escapeHtml(img) + '" alt="' + escapeHtml(p.title) + '">'
            : '') +
          '</a>' +
          qsBtn +
          '</div><div class="product-info-wrapper"><p class="product-name">' +
          escapeHtml(p.title) +
          '</p>' +
          priceHtml +
          sold +
          '</div>';
        container.appendChild(wrap);
      }

      var padBusy = false;
      async function pad() {
        if (padBusy) return;
        padBusy = true;
        try {
        var root = document.querySelector('.tvc-cross-sell-addons #cross-sell');
        if (!root || !handles.length) return;
        var container = root.querySelector('.collection-products.items');
        if (!container) return;
        if (itemCount(container) >= maxSlots) return;
        var shown = collectHandles(container);
        shown[currentHandle] = true;
        var orderSeq = 9000;
        for (var i = 0; i < handles.length; i++) {
          if (itemCount(container) >= maxSlots) break;
          var h = handles[i];
          if (!h || shown[h]) continue;
          try {
            var res = await fetch(productUrl(h) + '.js');
            if (!res.ok) continue;
            var p = await res.json();
            if (!p || !p.handle) continue;
            if (shown[p.handle]) continue;
            if (itemCount(container) >= maxSlots) break;
            shown[p.handle] = true;
            appendItem(container, p, orderSeq++);
          } catch (e) {}
        }
        } finally {
          padBusy = false;
        }
      }

      function run() {
        void pad();
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function () {
          setTimeout(run, 600);
          setTimeout(run, 2200);
        });
      } else {
        setTimeout(run, 600);
        setTimeout(run, 2200);
      }
    })();
  </script>
{%- endif -%}
