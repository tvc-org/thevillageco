{% comment %}
  Footer newsletter - Therapy-style: image left, form right (desktop);
  stacked image 1:1 + form (mobile). Mr Bubble overrides via brand class.
  Accepts: brand (optional) - footer brand block
{% endcomment %}
{%- liquid
  assign brand_slug = ''
  assign newsletter_image = null
  assign newsletter_image_mobile = null
  assign form_bg = ''
  assign form_ui_accent = ''
  if brand != blank
    assign brand_slug = brand.settings.text | handleize
    assign newsletter_image = brand.settings.footer_newsletter_background_image
    assign newsletter_image_mobile = brand.settings.footer_newsletter_background_image_mobile | default: newsletter_image
    assign form_bg = brand.settings.footer_newsletter_form_bg | default: '#e4dbd4'
    assign form_ui_accent = brand.settings.footer_newsletter_form_ui_accent
  else
    assign form_bg = '#e4dbd4'
  endif
  assign has_image = false
  if newsletter_image != blank
    assign has_image = true
  endif
-%}

{%- if form_bg != blank and form_bg != 'rgba(0,0,0,0)' -%}
  <style>
    .footer-newsletter-section{% if brand != blank %}.footer-newsletter--{{ brand_slug }}{% endif %} .footer-newsletter__form-col {
      background-color: {{ form_bg }};
    }
  </style>
{%- endif -%}
{%- if brand != blank and form_ui_accent != blank -%}
  <style>
    .footer-newsletter-section.footer-newsletter--{{ brand_slug }} {
      --footer-newsletter-form-ui-accent: {{ form_ui_accent }};
    }
  </style>
{%- endif -%}

<div class="footer-newsletter-section{% if brand != blank %} footer-newsletter--{{ brand_slug }}{% endif %}{% unless has_image %} footer-newsletter--no-image{% endunless %}">
  <div class="footer-newsletter__layout">
    {%- if has_image -%}
      <div class="footer-newsletter__image-col">
        {%- if newsletter_image_mobile != blank -%}
          {%- comment -%}
            Mobile-first: default <img> is the mobile asset so small viewports always load it.
            Desktop art uses <source media="(min-width: 961px)"> to match newsletter desktop layout.
          {%- endcomment -%}
          <picture>
            <source
              media="(min-width: 961px)"
              srcset="{{ newsletter_image | image_url: width: 1920 }}"
            >
            <img
              src="{{ newsletter_image_mobile | image_url: width: 750 }}"
              alt=""
              width="{{ newsletter_image_mobile.width }}"
              height="{{ newsletter_image_mobile.height }}"
              sizes="100vw"
              loading="lazy"
              class="footer-newsletter__image"
            >
          </picture>
        {%- else -%}
          <img
            src="{{ newsletter_image | image_url: width: 1920 }}"
            alt=""
            width="{{ newsletter_image.width }}"
            height="{{ newsletter_image.height }}"
            loading="lazy"
            class="footer-newsletter__image"
          >
        {%- endif -%}
      </div>
    {%- endif -%}
    <div class="footer-newsletter__form-col">
      <div class="footer-newsletter__form-inner">
        <div class="footer-newsletter__form">
          {{ settings.signup_embed }}
        </div>
      </div>
    </div>
  </div>
</div>

{%- comment -%}
  Hardcoded brand-specific newsletter styles (toggle via current brand).
  Add color, typography, spacing overrides per brand as needed.
{%- endcomment -%}
<style>
  /* Mr. Bubble */
  .footer-newsletter--mr-bubble {
    --footer-newsletter-text: #fff;
    --footer-newsletter-accent: #f04d98;
  }
  /* Village Naturals Therapy - dark text on beige form panel */
  .footer-newsletter--village-naturals-therapy {
    --footer-newsletter-text: #2d2d2d;
    --footer-newsletter-accent: #5f885f;
  }
  /* Soft&Dri */
  .footer-newsletter--soft-dri {
    --footer-newsletter-text: #fff;
    --footer-newsletter-accent: #da2171;
  }
  /* The Village Co. */
  .footer-newsletter--the-village-co {
    --footer-newsletter-text: #fff;
    --footer-newsletter-accent: #00a1dd;
  }
</style>
