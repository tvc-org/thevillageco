{% comment %}
  Tout nav featured image: custom, then Bonify custom_fields, then product/collection/article default image.
  Pass exactly one of: tout_product, tout_collection, tout_article
  (Do not use product/collection/article — those collide with Shopify template globals on PDP/collection/article pages.)
  - image_width: number for image_url width
  - image_widths: string for image_tag widths (e.g. '220, 440' or '280, 560')
  - image_sizes: optional sizes attribute (e.g. '280px')
  - load_lazy: if true, adds loading='lazy'
{% endcomment %}
{%- liquid
  assign tout_img = blank
  if tout_product != blank
    if tout_product.metafields.custom.featured_nav_image != blank
      assign tout_img = tout_product.metafields.custom.featured_nav_image.value
    elsif tout_product.metafields.custom_fields.featured_nav_image != blank
      assign tout_img = tout_product.metafields.custom_fields.featured_nav_image.value
    else
      assign tout_img = tout_product.featured_image
    endif
  elsif tout_collection != blank
    if tout_collection.metafields.custom.featured_nav_image != blank
      assign tout_img = tout_collection.metafields.custom.featured_nav_image.value
    elsif tout_collection.metafields.custom_fields.featured_nav_image != blank
      assign tout_img = tout_collection.metafields.custom_fields.featured_nav_image.value
    else
      assign tout_img = tout_collection.featured_image
    endif
  elsif tout_article != blank
    if tout_article.metafields.custom.featured_nav_image != blank
      assign tout_img = tout_article.metafields.custom.featured_nav_image.value
    elsif tout_article.metafields.custom_fields.featured_nav_image != blank
      assign tout_img = tout_article.metafields.custom_fields.featured_nav_image.value
    else
      assign tout_img = tout_article.image
    endif
  endif
-%}
{%- if image_sizes != blank -%}
  {%- if load_lazy -%}
    {{- tout_img | image_url: width: image_width | image_tag: widths: image_widths, sizes: image_sizes, loading: 'lazy' -}}
  {%- else -%}
    {{- tout_img | image_url: width: image_width | image_tag: widths: image_widths, sizes: image_sizes -}}
  {%- endif -%}
{%- elsif load_lazy -%}
  {{- tout_img | image_url: width: image_width | image_tag: widths: image_widths, loading: 'lazy' -}}
{%- else -%}
  {{- tout_img | image_url: width: image_width | image_tag: widths: image_widths -}}
{%- endif -%}
