{% comment %}
  Renders a utility content block (FAQ, legal, etc.).
  Pass: block (section block), or preset_* variables from utility presets.
{% endcomment %}
{%- liquid
  if block != blank
    assign section_title = block.settings.section_title
    assign section_subtitle = block.settings.section_subtitle
    assign section_accordion = block.settings.section_accordion
    assign section_details = block.settings.section_details
    assign shopify_attributes = block.shopify_attributes
  else
    assign section_title = preset_section_title
    assign section_subtitle = preset_section_subtitle
    assign section_accordion = preset_section_accordion
    assign section_details = preset_section_details
    assign shopify_attributes = ''
  endif

  assign section_id = section_title | default: 'section' | handleize
-%}
<section id="{{ section_id }}" {{ shopify_attributes }}>
  {%- if section_title != blank -%}
    <h2 class="utility-section-title">{{ section_title | escape }}</h2>
  {%- endif -%}
  {%- if section_subtitle != blank -%}
    <p class="utility-subtitle">{{ section_subtitle | escape }}</p>
  {%- endif -%}

  {%- if section_accordion -%}
    <div class="accordion-container tab-accordion-system">
      {%- assign raw_content = section_details -%}
      {%- assign accordion_systems = raw_content | split: 'accordion_title:' -%}
      {%- assign accordion_counter = 0 -%}
      {%- for accordion_system in accordion_systems -%}
        {%- if accordion_system != blank -%}
          {%- assign accordion_parts = accordion_system | split: 'accordion_content:' -%}
          <div class="system{% if accordion_counter == 0 %} active{% endif %}">
            <button type="button" class="system-title utility-subtitle system-title-{{ accordion_counter }}" data-target="system-{{ accordion_counter }}">
              {{ accordion_parts[0] | strip }}
            </button>
            <div class="system-content" data-target="system-{{ accordion_counter }}">
              <div class="content-inner rte">
                {{ accordion_parts[1] }}
              </div>
            </div>
          </div>
          {%- assign accordion_counter = accordion_counter | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- elsif section_details != blank -%}
    <div class="rte utility-section-body">
      {%- assign raw_content = section_details -%}
      {%- if raw_content contains ':paragraph:' -%}
        {%- assign paragraphs = raw_content | split: ':paragraph:' -%}
        {%- for paragraph in paragraphs -%}
          {%- if paragraph != blank -%}
            <p>{{ paragraph }}</p>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {{ raw_content }}
      {%- endif -%}
    </div>
  {%- endif -%}
</section>
