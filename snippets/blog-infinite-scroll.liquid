{% comment %}
  Infinite scroll for blog article grids.
{% endcomment %}

<collection-infinite-scroll
  class="collection-infinite-scroll"
  data-section-id="{{ section.id }}"
  data-grid-id="blog-grid"
  data-current-page="{{ paginate.current_page }}"
  data-total-pages="{{ paginate.pages }}"
  {% if paginate.next %}
    data-next-url="{{ paginate.next.url }}"
  {% endif %}
>
  <div class="collection-infinite-scroll__status" role="status" aria-live="polite">
    <div class="collection-infinite-scroll__loading hidden">
      {%- render 'loading-spinner' -%}
    </div>
  </div>
</collection-infinite-scroll>
