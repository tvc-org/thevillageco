{% comment %}
  SINGLE SOURCE OF TRUTH — current brand handle (e.g. mr-bubble).

  The header section owns brand blocks (nav menus, colors). All consumers call this snippet:

    sections/header.liquid  → render with brand_blocks: section.blocks (authoritative; runs first)
    sections/footer.liquid  → render with no args; reads sections['header'].blocks after header-group
    snippets/body-brand-class.liquid → render with no args; <head> may lack sections['header'], so
      handle-only rules apply until header-group renders (fonts / body class approximation)

  Shopify sections cannot share Liquid variables. Footer follows the header by re-running this
  snippet against the same header section blocks — not a second copy of the rules.

  Accepts:
    brand_blocks (optional) — header brand blocks; pass explicitly from sections/header.liquid
{% endcomment %}
{%- liquid
  assign resolved_brand_blocks = brand_blocks
  if resolved_brand_blocks == blank and sections['header'] != blank
    assign resolved_brand_blocks = sections['header'].blocks | where: 'type', 'brand'
  endif

  assign current_url = request.path
  assign url_segments = current_url | split: '/'
  assign last_segment = url_segments | last
  assign brand_handle = ''
-%}

{%- if resolved_brand_blocks.size > 0 -%}
  {%- liquid
    assign current_brand = resolved_brand_blocks | last
    for block in resolved_brand_blocks
      if block.settings.text == 'The Village Co.'
        assign current_brand = block
        break
      endif
    endfor

    for block in resolved_brand_blocks
      assign has_active_link = false
      if block.settings.menu != blank
        for link in block.settings.menu.links
          capture link_match
            render 'brand-menu-link-matches', link: link, current_url: current_url
          endcapture
          if link_match contains 'true'
            assign has_active_link = true
            break
          endif
          for child_link in link.links
            capture child_match
              render 'brand-menu-link-matches', link: child_link, current_url: current_url
            endcapture
            if child_match contains 'true'
              assign has_active_link = true
              break
            endif
            for grandchild_link in child_link.links
              capture grandchild_match
                render 'brand-menu-link-matches', link: grandchild_link, current_url: current_url
              endcapture
              if grandchild_match contains 'true'
                assign has_active_link = true
                break
              endif
            endfor
            if has_active_link
              break
            endif
          endfor
          if has_active_link
            break
          endif
        endfor
      endif
      if has_active_link
        assign current_brand = block
        break
      endif
    endfor

    for block in resolved_brand_blocks
      if block.settings.brand_page_link != blank
        if current_url contains block.settings.brand_page_link
          assign current_brand = block
          break
        elsif last_segment contains 'mr-bubble' and block.settings.brand_page_link contains 'mr-bubble'
          assign current_brand = block
          break
        elsif last_segment contains 'therapy' and block.settings.brand_page_link contains 'therapy'
          assign current_brand = block
          break
        endif
      endif
    endfor

    if template.suffix contains 'mr-bubble' or template.suffix contains 'kids-corner' or current_url contains 'mr-bubble' or current_url contains 'kids-corner' or last_segment contains 'mr-bubble' or last_segment contains 'kids-corner'
      for block in resolved_brand_blocks
        if block.settings.text == 'Mr. Bubble'
          assign current_brand = block
          break
        endif
      endfor
    elsif template.suffix contains 'therapy' or current_url contains 'therapy' or last_segment contains 'therapy'
      for block in resolved_brand_blocks
        if block.settings.text == 'Village Naturals Therapy'
          assign current_brand = block
          break
        endif
      endfor
    elsif template.suffix contains 'soft-dri' or current_url contains 'soft-dri' or last_segment contains 'soft-dri'
      for block in resolved_brand_blocks
        if block.settings.text == 'Soft&Dri'
          assign current_brand = block
          break
        endif
      endfor
    endif
  -%}
  {%- if product -%}
    {%- for block in resolved_brand_blocks -%}
      {%- if block.settings.text == product.vendor -%}
        {%- assign current_brand = block -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
  {%- if blog -%}
    {%- for block in resolved_brand_blocks -%}
      {%- if block.settings.text == 'Village Naturals Therapy' and blog.handle == 'village-naturals-therapy' -%}
        {%- assign current_brand = block -%}
        {%- break -%}
      {%- elsif block.settings.text == 'Mr. Bubble' and blog.handle == 'fun' -%}
        {%- assign current_brand = block -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
  {%- if collection -%}
    {%- assign collection_title_down = collection.title | downcase -%}
    {%- if collection_title_down contains 'therapy:' -%}
      {%- for block in resolved_brand_blocks -%}
        {%- if block.settings.text == 'Village Naturals Therapy' -%}
          {%- assign current_brand = block -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
    {%- elsif collection_title_down contains 'mr. bubble:' -%}
      {%- for block in resolved_brand_blocks -%}
        {%- if block.settings.text == 'Mr. Bubble' -%}
          {%- assign current_brand = block -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  {%- endif -%}
  {%- if current_brand != blank and current_brand.settings.text != blank -%}
    {%- assign brand_handle = current_brand.settings.text | handleize -%}
  {%- endif -%}
{%- else -%}
  {%- comment -%} No header blocks (theme <head> only) — handle-only rules, no nav matching {%- endcomment -%}
  {%- liquid
    if template.suffix contains 'mr-bubble' or template.suffix contains 'kids-corner' or current_url contains 'mr-bubble' or current_url contains 'kids-corner' or last_segment contains 'mr-bubble' or last_segment contains 'kids-corner'
      assign brand_handle = 'mr-bubble'
    elsif template.suffix contains 'therapy' or current_url contains 'therapy' or last_segment contains 'therapy'
      assign brand_handle = 'village-naturals-therapy'
    elsif template.suffix contains 'soft-dri' or current_url contains 'soft-dri' or last_segment contains 'soft-dri'
      assign brand_handle = 'soft-dri'
    endif
    if product and product.vendor != blank
      assign brand_handle = product.vendor | handleize
    endif
    if blog
      if blog.handle == 'village-naturals-therapy'
        assign brand_handle = 'village-naturals-therapy'
      elsif blog.handle == 'fun'
        assign brand_handle = 'mr-bubble'
      endif
    endif
    if collection
      assign collection_title_down = collection.title | downcase
      if collection_title_down contains 'therapy:'
        assign brand_handle = 'village-naturals-therapy'
      elsif collection_title_down contains 'mr. bubble:'
        assign brand_handle = 'mr-bubble'
      endif
    endif
  -%}
{%- endif -%}

{%- if brand_handle == blank -%}
  {%- assign brand_handle = 'the-village-co' -%}
{%- endif -%}

{{- brand_handle -}}
