{% comment %}
  Tout collection/article display title: custom, then Bonify custom_fields, then resource default.
  Pass exactly one of: tout_collection, tout_article
  (Do not use collection/article — those collide with Shopify template globals.)
{% endcomment %}
{%- liquid
  assign tout_nav_title = ''
  if tout_collection != blank
    if tout_collection.metafields.custom.featured_nav_title != blank
      assign tout_nav_title = tout_collection.metafields.custom.featured_nav_title.value
    elsif tout_collection.metafields.custom_fields.featured_nav_title != blank
      assign tout_nav_title = tout_collection.metafields.custom_fields.featured_nav_title.value
    else
      assign tout_nav_title = tout_collection.title
    endif
  elsif tout_article != blank
    if tout_article.metafields.custom.featured_nav_title != blank
      assign tout_nav_title = tout_article.metafields.custom.featured_nav_title.value
    elsif tout_article.metafields.custom_fields.featured_nav_title != blank
      assign tout_nav_title = tout_article.metafields.custom_fields.featured_nav_title.value
    else
      assign tout_nav_title = tout_article.title
    endif
  endif
-%}
{{- tout_nav_title -}}
