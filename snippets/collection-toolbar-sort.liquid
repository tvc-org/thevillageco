{% comment %}
  Collection PLP sort control (desktop toolbar + mobile exposed sort).

  Accepts:
  - results: {Object} Collection or Search object
  - select_id: {String} ID for the sort <select>
  - extra_classes: {String} Optional extra classes on the wrapper (optional)
{% endcomment %}
{%- liquid
  assign sort_by = results.sort_by | default: results.default_sort_by
-%}
<div class="facet-filters sorting caption collection-toolbar__sort{% if extra_classes != blank %} {{ extra_classes }}{% endif %}">
  <div class="facet-filters__field">
    <h2 class="facet-filters__label caption-large text-body">
      <label for="{{ select_id }}">{{ 'products.facets.sort_by_label' | t }}</label>
    </h2>
    <div class="select">
      <select
        name="sort_by"
        class="facet-filters__sort select__select caption-large"
        id="{{ select_id }}"
        aria-describedby="a11y-refresh-page-message"
      >
        {%- for option in results.sort_options -%}
          <option
            value="{{ option.value | escape }}"
            {% if option.value == sort_by %}
              selected="selected"
            {% endif %}
          >
            {{ option.name | escape }}
          </option>
        {%- endfor -%}
      </select>
      <span class="svg-wrapper">
        {{- 'icon-caret.svg' | inline_asset_content -}}
      </span>
    </div>
  </div>
</div>
