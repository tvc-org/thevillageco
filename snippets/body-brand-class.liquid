{% comment %}
  Appends the current brand handle as an extra class on <body> (see layout/theme.liquid).
  Delegates to snippets/resolve-brand-handle.liquid — no local matching rules here.
{% endcomment %}
{%- capture brand_body_handle -%}
  {%- render 'resolve-brand-handle' -%}
{%- endcapture -%}
{%- assign brand_body_handle = brand_body_handle | strip -%}
{%- if brand_body_handle != blank %} {{ brand_body_handle }}{% endif -%}
